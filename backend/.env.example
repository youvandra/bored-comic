# --- LLM ---
SUMOPOD_API_KEY=
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=deepseek-v4-flash

# --- Image Generation (Cloudflare Workers AI) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
# Optional extra accounts for quota fallback (add _2, _3, ... up to _8)
CLOUDFLARE_ACCOUNT_ID_2=
CLOUDFLARE_API_TOKEN_2=
CLOUDFLARE_ACCOUNT_ID_3=
CLOUDFLARE_API_TOKEN_3=
FLUX_STEPS=8

# --- X Layer API (for x402 settlement) ---
XLAYER_API_KEY=
XLAYER_SECRET_KEY=
XLAYER_PASSPHRASE=

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Storage ---
COMIC_DIR=/tmp/boredcomic
COMIC_TTL_MS=86400000
# Persistent store: characters, series, revisable job storyboards.
# Must survive restarts (unlike COMIC_DIR).
DATA_DIR=./data
# How long a job stays revisable via revise_page (default 7 days).
JOB_TTL_MS=604800000

# --- Delivery receipts ---
# HMAC key for signed delivery receipts. Unset = receipts unsigned.
RECEIPT_SECRET=

# --- x402 Payment ---
X402_MODE=off
X402_PAY_TO=
X402_PRICE_USD=0.05
