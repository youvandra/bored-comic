# --- LLM + Image Generation ---
SUMOPOD_API_KEY=
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=deepseek-v4-flash

# --- Image Generation (Replicate / FLUX) ---
REPLICATE_API_TOKEN=

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Storage ---
COMIC_DIR=/tmp/comicgen
COMIC_TTL_MS=86400000

# --- x402 Payment ---
X402_MODE=off
X402_PAY_TO=
X402_PRICE_USD=0.05
